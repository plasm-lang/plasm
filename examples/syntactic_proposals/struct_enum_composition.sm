// Warning: This example can't be compiled yet.
// It's written for syntax demonstration.

// It's possible to declare structs inside enums:

type Device = enum {
    CPU: struct { cores: i32 },
    GPU: struct { cores: i32, vmemory_size: usize },
}

// As well as to declare enums inside structs:

type Connection = struct {
    port: u16,
    status: enum { New, Opened, Closed },
}

// Often inside large codebases there is a need to combine separated
// datatypes with in-line defined, so there is special keyword `use`
// to mark difference between new and existing types:

type Quaternion = struct {
    w: f32,
    x: f32,
    y: f32,
    z: f32,
}

type Orientation = enum {
    Euler { x: f32, y: f32, z: f32 },
    use Quaternion,
}

// With `use` notation there is no need to write `Quaternion(Quaternion)`
// to make a types composition.

// I find this composition abbilities espessially useful for heavy DTO descriptions:

// A globally defined struct that we want to reuse
type Transform = struct {
    x: f32,
    y: f32,
    z: f32,
}

// A heavy DTO representing a network event
type ServerPacket = struct {
    packet_id: u64,
    timestamp: u64,
    
    // Deep inline composition
    payload: enum {
        // Inline struct with an inline enum inside
        PlayerJoined: struct {
            user_id: u32,
            nickname: String,
            role: enum { Player, Moderator, Admin },
        },

        // Reusing existing type `Transform` inside a variant
        PlayerRotated: struct {
            client_id: u32,
            use Transform, 
        },

        // Deeply nested enums for complex states without Option/Result
        Disconnected: struct {
            reason: enum {
                Timeout,
                Kicked: struct { admin_id: u32, message: String | None },
                Banned: struct { expires_at: u64 | None }, 
            }
        },

        // A simple unit variant
        Ping,
    }
}
