// To write a promised (external) function that will be recived on linking
// stage just don't write brackets `{}` and function body.
// C ABI/FFI will be used. Plasm has no its own public and stable ABI.

fn sum(x1: i32, x2: i32) -> i32

fn print_u8(x: u8) -> void

fn print_i32(x: i32)
// `void` is not nessesary

fn main() {
    let x = 42
    let y = sum(x, 15)
    print_i32(y)
    print_u8(255) 
}
